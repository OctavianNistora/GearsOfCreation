MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: b53048e3c279aed4aa1b69e2a16b0588, type: 3}
  m_Name: DialogueGlassyWaters
  m_EditorClassIdentifier: Assembly-CSharp::DialogueSequence
  lines:
  - speaker: {fileID: 11400000, guid: 9be1affc12822ae4b9b4cdc0a91305b4, type: 2}
    text: Woah... That was a close one!
    voiceLine: {fileID: 0}
  - speaker: {fileID: 11400000, guid: 9be1affc12822ae4b9b4cdc0a91305b4, type: 2}
    text: Good thing I managed to catch you on your way here...
    voiceLine: {fileID: 0}
  - speaker: {fileID: 11400000, guid: 9be1affc12822ae4b9b4cdc0a91305b4, type: 2}
    text: Wait... where did you even come from? Are you lost?
    voiceLine: {fileID: 0}
  - speaker: {fileID: 11400000, guid: 9be1affc12822ae4b9b4cdc0a91305b4, type: 2}
    text: No matter. Robot or human... I'm here to protect you!
    voiceLine: {fileID: 0}
  - speaker: {fileID: 11400000, guid: 9be1affc12822ae4b9b4cdc0a91305b4, type: 2}
    text: (but only during combat)
    voiceLine: {fileID: 0}
  - speaker: {fileID: 11400000, guid: 9be1affc12822ae4b9b4cdc0a91305b4, type: 2}
    text: (you have to finish the platformer sequence by yourself)
    voiceLine: {fileID: 0}
  - speaker: {fileID: 11400000, guid: 9be1affc12822ae4b9b4cdc0a91305b4, type: 2}
    text: Watch out for the slippery tiles, I might not be able to catch you again!
    voiceLine: {fileID: 0}
